# Copia este archivo a .env y completa los valores reales.
# Ver docs/operations/configuration.md para el detalle de cada variable.

# ── Conexión a PostgreSQL ──────────────────────────────────────────────
# DATABASE_URL: la usa la app en runtime (PrismaClient). En Supabase, usa el
#   "Connection pooler" (pgBouncer, puerto 6543, con ?pgbouncer=true) — está
#   pensado para muchas conexiones cortas.
# DIRECT_URL: conexión DIRECTA (puerto 5432). La usan las herramientas de
#   esquema (`prisma db push` / `migrate`), porque pgBouncer no soporta DDL en
#   modo transacción. En Supabase: Project Settings → Database → Connection
#   string → "Direct connection". Si trabajas 100% local, puedes dejar solo
#   DATABASE_URL (DIRECT_URL cae de vuelta a ella).
DATABASE_URL="postgresql://usuario:password@localhost:5432/erp_tienda"
DIRECT_URL="postgresql://usuario:password@localhost:5432/erp_tienda"

# Secreto para firmar/verificar los JWT. Obligatorio: el servidor no arranca
# sin esta variable. Usa un valor largo y aleatorio (ej. openssl rand -hex 32).
JWT_SECRET="reemplaza-con-un-secreto-largo-y-aleatorio"

# Puerto donde escucha el backend (opcional, por defecto 3000).
PORT=3000

# Contraseña del usuario "admin" que se crea automáticamente la primera vez
# que el sistema arranca con la tabla de usuarios vacía. Si esta variable no
# está definida, NO se crea ningún admin (ver docs/decisions/0003).
INITIAL_ADMIN_PASSWORD="cambia-esta-contraseña"

# Orígenes permitidos por CORS, separados por coma. Por defecto solo el
# frontend de desarrollo local.
CORS_ORIGINS="http://localhost:3001"

# Entorno de ejecución. En "production" se desactiva Swagger a menos que
# ENABLE_SWAGGER=true.
NODE_ENV=development

# Fuerza Swagger encendido aunque NODE_ENV=production (opcional).
# ENABLE_SWAGGER=true
