  lote_id             Int
  cantidad_descargada Decimal          @db.Decimal(12, 3)
  costo_aplicado      Decimal          @db.Decimal(10, 4)
  detalle_ventas      detalle_ventas   @relation(fields: [detalle_venta_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_detalle_venta")
  lotes_inventario    lotes_inventario @relation(fields: [lote_id], references: [id], onUpdate: NoAction, map: "fk_lote_descarga")

  @@index([detalle_venta_id])
  @@index([lote_id])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model detalle_ventas {
  id                  Int                   @id @default(autoincrement())
  venta_id            Int
  presentacion_id     Int
  cantidad            Decimal               @db.Decimal(12, 3)
  subtotal            Decimal               @db.Decimal(10, 2)
  detalle_venta_lotes detalle_venta_lotes[]
  presentaciones      presentaciones        @relation(fields: [presentacion_id], references: [id], onUpdate: NoAction, map: "fk_presentacion")
  ventas              ventas                @relation(fields: [venta_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_venta")

  @@index([venta_id])
  @@index([presentacion_id])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model lotes_inventario {
  id                         Int                   @id @default(autoincrement())
  producto_id                Int
  compra_id                  Int
  costo_unitario_adquisicion Decimal               @db.Decimal(10, 4)
  cantidad_inicial           Decimal               @db.Decimal(12, 3)
  cantidad_disponible        Decimal               @db.Decimal(12, 3)
  fecha_ingreso              DateTime?             @default(now()) @db.Timestamptz(6)
  fecha_vencimiento          DateTime?             @db.Date
  ajustes_inventario         ajustes_inventario[]
  detalle_venta_lotes        detalle_venta_lotes[]
  compras_inventario         compras_inventario    @relation(fields: [compra_id], references: [id], onUpdate: NoAction, map: "fk_compra_lote")
  productos                  productos             @relation(fields: [producto_id], references: [id], onUpdate: NoAction, map: "fk_producto_lote")

  // Índice compuesto para el motor FIFO: ventas.service.ts filtra por
  // producto_id y ordena por fecha_ingreso ASC bajo FOR UPDATE (ver ADR 0001).
  // Este es el índice de mayor impacto de Fase 1 — acelera exactamente esa
  // consulta y reduce el tiempo que el lock de fila permanece retenido.
  @@index([producto_id, fecha_ingreso])
  @@index([compra_id])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model movimientos_financieros {
  id                 Int                @id @default(autoincrement())
  caja_turno_id      Int?
  tipo_movimiento    String             @db.VarChar(50)
  monto              Decimal            @db.Decimal(10, 2)
  categoria_gasto_id Int?
  descripcion        String
  fecha              DateTime?          @default(now()) @db.Timestamptz(6)
  usuario_id         Int?
  // Modelo origen→destino (Bloque 1 §5.1): catálogo cerrado
  // GAVETA/BOVEDA/DUEÑOS/GASTO/PROVEEDOR. Nullable porque MERMA_INVENTARIO no es
  // un movimiento de efectivo. El saldo de bóveda se deriva de estas columnas.
  cuenta_origen      String?            @db.VarChar(20)
  cuenta_destino     String?            @db.VarChar(20)
  cajas_turnos       cajas_turnos?      @relation(fields: [caja_turno_id], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "fk_caja_movimiento")
  categorias_gastos  categorias_gastos? @relation(fields: [categoria_gasto_id], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "fk_categoria_gasto")
  usuarios           usuarios?          @relation(fields: [usuario_id], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_usuario_movimiento")

  // reportes.service.ts filtra siempre tipo_movimiento + fecha juntos
  // (gastos operativos, mermas). findAll(tipo_movimiento) también lo usa solo.
  @@index([tipo_movimiento, fecha])
  @@index([caja_turno_id])
  @@index([categoria_gasto_id])
  @@index([usuario_id])
  // Saldo de bóveda derivado: Σ(destino=BOVEDA) − Σ(origen=BOVEDA).
  @@index([cuenta_destino])
  @@index([cuenta_origen])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model presentaciones {
  id                Int              @id @default(autoincrement())
  producto_id       Int
  codigo_barras     String?          @unique @db.VarChar(50)
  descripcion       String           @db.VarChar(100)
  factor_conversion Decimal          @db.Decimal(12, 3)
  precio_venta      Decimal          @db.Decimal(10, 2)
  detalle_ventas    detalle_ventas[]
  productos         productos        @relation(fields: [producto_id], references: [id], onUpdate: NoAction, map: "fk_producto")

  @@index([producto_id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model productos {
  id               Int                @id @default(autoincrement())
  nombre           String             @db.VarChar(150)
  categoria_id     Int
  created_at       DateTime?          @default(now()) @db.Timestamptz(6)
  lotes_inventario lotes_inventario[]
  presentaciones   presentaciones[]
  categorias       categorias         @relation(fields: [categoria_id], references: [id], onUpdate: NoAction, map: "fk_categoria")

  @@index([categoria_id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model usuarios {
  id            Int       @id @default(autoincrement())
  nombre        String    @unique @db.VarChar(100)
  rol           String    @db.VarChar(20)
  password_hash String    @db.VarChar(255)
  created_at    DateTime? @default(now()) @db.Timestamptz(6)

  // Trazabilidad de autor (Bloque 1, §5.2). Back-relations de usuario_id.
  cajas_turnos            cajas_turnos[]
  ventas                  ventas[]
  movimientos_financieros movimientos_financieros[]
  ajustes_inventario      ajustes_inventario[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ventas {
  id                 Int              @id @default(autoincrement())
  caja_turno_id      Int
  total              Decimal          @db.Decimal(10, 2)
  fecha              DateTime?        @default(now()) @db.Timestamptz(6)
  estado             String           @default("COMPLETADA") @db.VarChar(20)
  justificacion_nula String?          @db.Text
  fecha_anulacion    DateTime?        @db.Timestamptz(6)
  usuario_id         Int?
  detalle_ventas     detalle_ventas[]
  cajas_turnos       cajas_turnos     @relation(fields: [caja_turno_id], references: [id], onUpdate: NoAction, map: "fk_caja_venta")
  usuarios           usuarios?        @relation(fields: [usuario_id], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_usuario_venta")

  // reportes.service.ts filtra siempre estado + fecha juntos (estado de
  // resultados, productos top, margen por producto).
  @@index([estado, fecha])
  @@index([caja_turno_id])
  @@index([usuario_id])
}

