generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model activos_fijos {
  id                Int       @id @default(autoincrement())
  nombre            String    @db.VarChar(150)
  valor_estimado    Decimal   @db.Decimal(10, 2)
  fecha_adquisicion DateTime  @db.Date
  created_at        DateTime? @default(now()) @db.Timestamptz(6)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ajustes_inventario {
  id                Int              @id @default(autoincrement())
  lote_id           Int
  cantidad_ajustada Decimal          @db.Decimal(12, 3)
  tipo_ajuste       String           @db.VarChar(50)
  costo_asumido     Decimal          @db.Decimal(10, 2)
  fecha             DateTime?        @default(now()) @db.Timestamptz(6)
  justificacion     String?
  usuario_id        Int?
  lotes_inventario  lotes_inventario @relation(fields: [lote_id], references: [id], onUpdate: NoAction, map: "fk_lote_ajuste")
  usuarios          usuarios?        @relation(fields: [usuario_id], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_usuario_ajuste")

  @@index([lote_id])
  @@index([usuario_id])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model cajas_turnos {
  id                      Int                       @id @default(autoincrement())
  fecha_apertura          DateTime?                 @default(now()) @db.Timestamptz(6)
  fondo_inicial           Decimal                   @db.Decimal(10, 2)
  estado                  String                    @default("ABIERTA") @db.VarChar(20)
  fecha_cierre            DateTime?                 @db.Timestamptz(6)
  efectivo_esperado       Decimal?                  @db.Decimal(10, 2)
  efectivo_declarado      Decimal?                  @db.Decimal(10, 2)
  diferencia              Decimal?                  @db.Decimal(10, 2)
  observaciones           String?
  usuario_id              Int?
  movimientos_financieros movimientos_financieros[]
  ventas                  ventas[]
  usuarios                usuarios?                 @relation(fields: [usuario_id], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_usuario_caja_turno")

  // Casi toda operación de escritura (ventas, compras, egresos, ajustes,
  // abrir/cerrar turno) busca "el turno ABIERTA"; abrir() y getUltimoCierre()
  // buscan además el CERRADA más reciente por fecha_cierre. Este índice
  // compuesto sirve ambas consultas (ver docs/decisions/0005-indices-bd.md).
  @@index([estado, fecha_cierre])
  @@index([usuario_id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model categorias {
  id        Int         @id @default(autoincrement())
  nombre    String      @unique @db.VarChar(100)
  productos productos[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model categorias_gastos {
  id                      Int                       @id @default(autoincrement())
  nombre                  String                    @unique @db.VarChar(100)
  tipo                    String                    @db.VarChar(20)
  movimientos_financieros movimientos_financieros[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
