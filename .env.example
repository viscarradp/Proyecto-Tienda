# Variables para docker-compose (raíz del proyecto).
# Copia este archivo a ".env" en la raíz para sobreescribir los valores por
# defecto que trae docker-compose.yml. Si no creas ese ".env", docker-compose
# usa los defaults definidos ahí mismo (ver "${VAR:-default}").
#
# IMPORTANTE: este .env es solo para docker-compose (levantar los 3
# contenedores). No tiene relación con erp-tienda-backend/.env ni con
# erp-tienda-frontend/.env.local, que son para correr esos proyectos SIN
# Docker. No mezcles ambos flujos: si usas docker-compose, las variables
# que importan son las de este archivo (docker-compose las inyecta dentro
# de los contenedores); los .env de cada subcarpeta se ignoran en ese caso.

# JWT Secret para firmar tokens (cambia esto en producción).
# Genera uno con: openssl rand -hex 32
JWT_SECRET=dev-secret-cambiar-en-produccion

# Contraseña del usuario admin inicial (se crea automáticamente si la tabla
# de usuarios está vacía al arrancar).
INITIAL_ADMIN_PASSWORD=Admin123!
